# Credenciales / configuración de connectors — COPIAR a .env (que está en .gitignore) y completar.
# NUNCA versionar el .env real.

# --- Connector arca (Constancia / Padrón AFIP vía microservicio afip-ws) ---
# El connector arca NO maneja el certificado de AFIP: es un cliente HTTP del microservicio
# afip-ws que ya corre en el VPS de NU (cert. de NU, mismo que Odoo). Acá solo va la URL base
# del afip-ws, alcanzable por la red Tailscale del VPS.
# El VPS es vmi2982897 = 100.88.25.41. El afip-ws ya está expuesto a la red Tailscale en el
# puerto 8001 (binding 100.88.25.41:8001 en su docker-compose). Requiere estar conectado a la
# VPN Tailscale de GrupoNU. Valor operativo:
AFIP_WS_BASE_URL=http://100.88.25.41:8001

# --- Connector odoo (contabilidad de NU vía Odoo 18 XML-RPC) ---
# El connector odoo opera la contabilidad de NU en Odoo (base gruponu_production) por la API
# XML-RPC oficial. ODOO_URL y ODOO_DB ya van en el .mcp.json del plugin (no son secretos).
# La API KEY y el usuario SÍ son secretos -> van acá en .env (gitignored), NUNCA en el repo.
# Requiere VPN Tailscale activa (odoo.gruponu.com va por la red privada).
# ODOO_COMPANY_ID: id numérico de la compañía NU Desarrollos (hay 2 en la base: NU y Vastu) —
# se obtiene con odoo_get_company() y sirve para que el connector no mezcle compañías.
ODOO_URL=https://odoo.gruponu.com
ODOO_DB=gruponu_production
ODOO_USER=
ODOO_API_KEY=
ODOO_COMPANY_ID=

